GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
NOTIFY_EMAIL=your-email@gmail.com
VENUE_NAME=Venue Name
GOOGLE_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
# === Telegram notification (optional — bỏ trống để tắt) ===
# Token từ @BotFather: /newbot → lấy HTTP API Token
TELEGRAM_BOT_TOKEN=
# Chat ID group team (âm, bắt đầu -100...). Lấy qua getUpdates sau khi add bot vào group
TELEGRAM_CHAT_ID=

# === Google Ads + Analytics ===
# Google Ads conversion ID (format AW-XXXXXXXXXX) — gắn từ Ads dashboard
NEXT_PUBLIC_AW_ID=
# Google Analytics 4 measurement ID (format G-XXXXXXXX) — optional
NEXT_PUBLIC_GA_ID=
# Conversion label cho event form_success (format AW-XXXXXXXXXX/abcXYZ123) —
# tạo conversion action trong Ads, điền send_to label sau /
NEXT_PUBLIC_AW_CONVERSION_LABEL=
